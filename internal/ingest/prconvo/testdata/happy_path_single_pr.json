{
  "version": 1,
  "interactions": [
    {
      "request": {
        "method": "POST",
        "url": "https://api.github.com/graphql",
        "body": {
          "query": "query($owner: String!, $repo: String!, $number: Int!, $first: Int!, $after: String) {\n  repository(owner: $owner, name: $repo) {\n    pullRequest(number: $number) {\n      reviews(first: $first, after: $after) {\n        pageInfo { hasNextPage endCursor }\n        nodes {\n          databaseId state submittedAt\n          author {\n            __typename\n            login\n            ... on User { databaseId }\n            ... on Bot { databaseId }\n            ... on Mannequin { databaseId }\n          }\n        }\n      }\n    }\n  }\n}",
          "variables": {
            "after": null,
            "first": 100,
            "number": 101,
            "owner": "karnstack",
            "repo": "tempo"
          }
        }
      },
      "response": {
        "status": 200,
        "body": {
          "data": {
            "repository": {
              "pullRequest": {
                "reviews": {
                  "nodes": [
                    {
                      "author": {
                        "__typename": "User",
                        "databaseId": 2001,
                        "login": "alice"
                      },
